# DeepSeek Client - Configuración de ejemplo
# Copia este archivo como .env y ajusta los valores según necesites

# ============================================================================
# ANTI-DETECCIÓN
# ============================================================================

# Nivel de anti-detección
# Opciones: basic, standard, full
# - basic: Solo spoofing de WebDriver y navigator
# - standard: + Canvas, WebGL, Screen
# - full: Todas las técnicas (recomendado)
ANTI_DETECTION_LEVEL=full

# Perfil de fingerprint
# Opciones: random, gaming_pc, work_laptop, macbook, linux_dev, etc.
# Ver profiles.py para lista completa
FINGERPRINT_PROFILE=random

# ============================================================================
# NAVEGADOR
# ============================================================================

# Ejecutar en modo headless (sin interfaz gráfica)
# Nota: El modo headless es más susceptible a detección
HEADLESS=false

# Usar Xvfb en Linux (display virtual)
USE_XVFB=false

# ============================================================================
# POOL DE DRIVERS
# ============================================================================

# Número de navegadores en el pool (para paralelismo)
DRIVER_POOL_SIZE=1

# ============================================================================
# DEEPSEEK
# ============================================================================

# URL de DeepSeek (normalmente no necesita cambiar)
DEEPSEEK_URL=https://chat.deepseek.com

# ============================================================================
# LOGGING
# ============================================================================

# Nivel de logging
# Opciones: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============================================================================
# TIMEOUTS (en segundos)
# ============================================================================

# Timeout de carga de página
# PAGE_LOAD_TIMEOUT=60

# Timeout de espera de elementos
# ELEMENT_WAIT_TIMEOUT=30

# Timeout para respuestas largas
# RESPONSE_TIMEOUT=300

# ============================================================================
# COMPORTAMIENTO HUMANO
# ============================================================================

# Velocidad de escritura (ms por carácter)
# TYPING_SPEED_MEAN=50
# TYPING_SPEED_STD=20

# Tasa de errores de escritura (0-1)
# TYPING_ERROR_RATE=0.02

# ============================================================================
# REINTENTOS
# ============================================================================

# Número de reintentos ante errores
# RETRY_ATTEMPTS=3

# Delay base entre reintentos (segundos)
# RETRY_DELAY=5.0
